<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <!-- Exclude generated files in obj/bin from being compiled twice -->
  <ItemGroup>
    <Compile Remove="FactoryOpsApp.Infrastructure\Implementations\Services\NewFolder\**" />
    <Compile Remove="obj\**\*.cs" />
    <Compile Remove="bin\**\*.cs" />
    <Content Remove="FactoryOpsApp.Infrastructure\Implementations\Services\NewFolder\**" />
    <EmbeddedResource Remove="FactoryOpsApp.Infrastructure\Implementations\Services\NewFolder\**" />
    <None Remove="FactoryOpsApp.Infrastructure\Implementations\Services\NewFolder\**" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Middleware\vtfxxuu1.k10~" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AspNetCore.HealthChecks.Kafka" Version="7.0.0" />
